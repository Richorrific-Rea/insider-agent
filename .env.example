# ── REQUIRED ──────────────────────────────────────────────────────────────────
# SEC EDGAR fair-access policy requires an identifiable User-Agent with contact.
EDGAR_USER_AGENT="Your Name your@email.com"

# ── OPTIONAL: Feed ────────────────────────────────────────────────────────────
# Number of most-recent Form 4 filings to fetch per cycle (max 100 for Atom feed).
FEED_COUNT=100

# ── OPTIONAL: Filters ─────────────────────────────────────────────────────────
# Only consider open-market purchases (transaction code P).
ONLY_OPEN_MARKET_PURCHASE=true

# Comma-separated list of roles to include.
ALLOWED_ROLES=CEO,CFO,PRES,DIR

# Minimum total trade value in USD.
MIN_TRADE_VALUE_USD=50000

# Minimum fractional increase in ownership (0.0 = no minimum).
MIN_DELTA_OWN_PCT=0.0

# Cluster detection: window in calendar days.
CLUSTER_WINDOW_DAYS=7

# Cluster detection: minimum number of distinct insiders.
CLUSTER_MIN_INSIDERS=2

# ── OPTIONAL: LLM (cualquier proveedor) ───────────────────────────────────────
# Proveedor: anthropic | openai | groq | gemini | ollama | custom
# Deja vacío para usar texto plano como fallback (sin costo).
LLM_PROVIDER=anthropic

# API key del proveedor elegido
LLM_API_KEY=REPLACE_ME

# Modelo (si está vacío se usa el default del proveedor):
#   anthropic → claude-haiku-3-5      openai  → gpt-4o-mini
#   groq      → llama-3.1-70b         gemini  → gemini-1.5-flash
#   ollama    → llama3.2              custom  → gpt-4o-mini
LLM_MODEL=

# Solo para ollama o APIs compatibles con OpenAI (LLM_PROVIDER=custom)
LLM_BASE_URL=

# ── Retrocompatibilidad: si ya tienes ANTHROPIC_API_KEY, sigue funcionando ────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Guía rápida por proveedor ──────────────────────────────────────────────────
# GROQ (gratis):
#   LLM_PROVIDER=groq
#   LLM_API_KEY=gsk_...   (consigue tu key en console.groq.com)
#
# GEMINI (gratis):
#   LLM_PROVIDER=gemini
#   LLM_API_KEY=AIza...   (consigue tu key en aistudio.google.com)
#
# OPENAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...    (platform.openai.com)
#   LLM_MODEL=gpt-4o-mini
#
# OLLAMA (local, sin internet):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3.2    (corre: ollama pull llama3.2)

# ── OPTIONAL: Telegram ────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather in Telegram → copy the token it gives you.
# 2. Send any message to the bot (or add it to a group/channel).
# 3. Get your chat ID:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    Look for "chat":{"id": ...} in the response.
# Leave empty to skip notifications (use --dry-run for local output).
TELEGRAM_BOT_TOKEN=123456789:REPLACE_ME_WITH_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_ME_WITH_CHAT_ID

# ── OPTIONAL: Price spike detection ──────────────────────────────────────────
# Min % change for portfolio / signal confirmation alerts (volume no longer required).
PRICE_SPIKE_PCT=5.0
# Min % change for standalone watchlist alerts (no signal correlation needed).
# Tiers: 7-12% NOTABLE | 12-18% FUERTE | 18%+ EXTREMO
WATCHLIST_SPIKE_PCT=7.0
# Min % DROP to alert on portfolio positions and watchlist tickers.
# Tiers: 5-10% NOTABLE | 10-15% FUERTE | 15%+ EXTREMO
PRICE_DROP_PCT=5.0
WATCHLIST_DROP_PCT=7.0

# ── OPTIONAL: Congressional confluence ───────────────────────────────────────
# Enable cross-referencing insider buys with congressional trading disclosures.
USE_CONGRESS_DATA=true
# How many days back to look for politician trades (Senate EFTS + House eFD).
CONGRESS_DAYS_BACK=30
# Insider and politician trades must be within this many days of each other.
CONFLUENCE_WINDOW_DAYS=14
# Min number of politicians buying same ticker to elevate confidence level.
CONFLUENCE_MIN_POLITICIANS=1

# ── OPTIONAL: State backend ───────────────────────────────────────────────────
# "file" (default) | "firestore" | "gcs"
STATE_BACKEND=file

# Path to local state file (only used when STATE_BACKEND=file).
STATE_FILE_PATH=state.json

# GCP project ID (required for firestore/gcs backends).
GCP_PROJECT=your-gcp-project-id

# Firestore collection name (only used when STATE_BACKEND=firestore).
FIRESTORE_COLLECTION=insider_agent_state

# GCS bucket and object (only used when STATE_BACKEND=gcs).
GCS_BUCKET=your-gcs-bucket-name
GCS_OBJECT=insider_agent_state.json
